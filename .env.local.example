NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public base for R2 object keys (profile/listings). Defaults to https://cdn.burrow.in if unset.
NEXT_PUBLIC_R2_PUBLIC_URL=

# Google Maps (browse map + listing preview). If you see "This page can't load Google Maps correctly":
# 1) Google Cloud Console → enable "Maps JavaScript API" on the same project as the key.
# 2) Enable billing for that project (Maps requires it).
# 3) Credentials → your API key → Application restrictions: if "HTTP referrers", add:
#    http://localhost:3000/*   http://127.0.0.1:3000/*   (and your production origins).
# 4) Create a Map ID (Maps → Map Management → Map IDs, vector map) and set NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID
#    — recommended for AdvancedMarker; without it some keys/projects fail to load.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_SENTRY_DSN_WEB=
